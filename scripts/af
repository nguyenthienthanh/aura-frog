#!/bin/bash
# af — Aura Frog CLI wrapper
# Zero dependencies, pure bash
# Install: af setup cli

REPO="nguyenthienthanh/aura-frog"

# Auto-detect plugin location
find_plugin_dir() {
  # 1. Marketplace install (most users)
  local marketplace="$HOME/.claude/plugins/marketplaces/aurafrog/aura-frog"
  [ -d "$marketplace" ] && echo "$marketplace" && return

  # 2. Local repo (developers)
  local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local local_repo="$(dirname "$script_dir")/aura-frog"
  [ -d "$local_repo" ] && echo "$local_repo" && return

  # 3. Current directory
  [ -d "aura-frog" ] && echo "aura-frog" && return

  echo ""
}

PLUGIN_DIR="$(find_plugin_dir)"
VERSION="unknown"
if [ -n "$PLUGIN_DIR" ] && [ -f "$PLUGIN_DIR/.claude-plugin/plugin.json" ]; then
  VERSION=$(grep '"version"' "$PLUGIN_DIR/.claude-plugin/plugin.json" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || echo "unknown")
fi

# ─── Setup subcommands ───────────────────────────────────────────────
handle_setup() {
  case "${1:-}" in
    cli)
      echo "🐸 Install af CLI globally"
      echo "=========================="
      echo ""
      # Find the af script location
      local af_path="${BASH_SOURCE[0]}"
      if [ ! -f "$af_path" ]; then
        # Try marketplace location
        af_path="$HOME/.claude/plugins/marketplaces/aurafrog/scripts/af"
      fi

      if [ ! -f "$af_path" ]; then
        echo "❌ Could not find af script"
        echo "   Run this inside Claude Code: setup:cli"
        return 1
      fi

      local target="/usr/local/bin/af"
      echo "This will create a symlink:"
      echo "  $target → $af_path"
      echo ""
      read -p "Proceed? (y/n) " -n 1 -r
      echo ""
      if [[ $REPLY =~ ^[Yy]$ ]]; then
        if ln -sf "$af_path" "$target" 2>/dev/null; then
          echo "✅ Installed! Type 'af' anywhere to use."
        else
          echo "⚠️  Permission denied. Try with sudo:"
          echo "  sudo ln -sf \"$af_path\" $target"
        fi
      else
        echo "Cancelled."
        echo ""
        echo "Manual install options:"
        echo "  # Option 1: Symlink (recommended)"
        echo "  sudo ln -sf \"$af_path\" /usr/local/bin/af"
        echo ""
        echo "  # Option 2: Add to PATH"
        echo "  echo 'export PATH=\"\$HOME/.claude/plugins/marketplaces/aurafrog/scripts:\$PATH\"' >> ~/.zshrc"
      fi
      ;;

    remote)
      echo "🐸 Remote Control Setup"
      echo "======================="
      echo ""
      echo "Remote Control lets you drive Claude Code from your phone or browser."
      echo ""
      echo "Start a session with remote control:"
      echo "  claude --remote-control"
      echo ""
      echo "This generates a URL + QR code. Open it on claude.ai or scan with your phone."
      echo ""
      echo "Features:"
      echo "  - Approve/deny permissions from phone"
      echo "  - Send messages to running session"
      echo "  - View Claude's output in real-time"
      echo ""
      echo "Named session:"
      echo "  claude --remote-control --name \"My Project\""
      ;;

    channels)
      echo "🐸 Channels Setup (Research Preview)"
      echo "====================================="
      echo ""
      echo "Channels push external events INTO your Claude Code session."
      echo "Requires Claude Code v2.1.80+ and claude.ai login."
      echo ""
      echo "── Telegram ──────────────────────────"
      echo "  1. Create bot via @BotFather on Telegram"
      echo "  2. In Claude Code:"
      echo "     /plugin install telegram@claude-plugins-official"
      echo "     /telegram:configure <your-bot-token>"
      echo "  3. Start session:"
      echo "     claude --channels plugin:telegram@claude-plugins-official"
      echo "  4. DM your bot → get pairing code → /telegram:access pair <code>"
      echo ""
      echo "── Discord ───────────────────────────"
      echo "  1. Create bot in Discord Developer Portal"
      echo "  2. In Claude Code:"
      echo "     /plugin install discord@claude-plugins-official"
      echo "  3. Start session:"
      echo "     claude --channels plugin:discord@claude-plugins-official"
      echo ""
      echo "── Custom Webhook ────────────────────"
      echo "  Build an MCP server that emits notifications/claude/channel events."
      echo "  See: https://docs.anthropic.com/en/docs/claude-code/channels"
      echo ""
      echo "── Test (fakechat) ───────────────────"
      echo "  claude --channels plugin:fakechat@claude-plugins-official"
      ;;

    slack)
      echo "🐸 Slack MCP Setup"
      echo "==================="
      echo ""
      echo "Aura Frog bundles a Slack MCP server for notifications."
      echo ""
      echo "1. Create Slack App: https://api.slack.com/apps"
      echo "   - Add scopes: chat:write, channels:history, channels:read, users:read"
      echo "   - Install to workspace → get Bot Token (xoxb-...)"
      echo ""
      echo "2. Add to your .envrc:"
      echo "   export SLACK_BOT_TOKEN=\"xoxb-your-token\""
      echo "   export SLACK_TEAM_ID=\"T0123456789\""
      echo ""
      echo "3. Reload env in Claude Code:"
      echo "   project:reload-env"
      echo ""
      echo "4. Test:"
      echo "   Ask Claude to post a message to a Slack channel."
      echo ""
      echo "Aura Frog auto-invokes Slack MCP for Phase 9 notifications"
      echo "and workflow completion alerts."
      ;;

    schedule)
      echo "🐸 Scheduled Tasks Setup"
      echo "========================="
      echo ""
      echo "── Session-scoped (dies when you exit) ──"
      echo "  /loop 5m check if the deployment finished"
      echo "  /loop 30m /review-pr 1234"
      echo "  /loop 1h check CI status"
      echo ""
      echo "── Cron expressions ──"
      echo "  */5 * * * *     Every 5 minutes"
      echo "  0 9 * * *       Daily at 9am"
      echo "  0 9 * * 1-5     Weekdays at 9am"
      echo ""
      echo "── Cloud tasks (persistent, no machine needed) ──"
      echo "  Use /schedule in Claude Code to create remote agents"
      echo "  that run on Anthropic's cloud on a cron schedule."
      echo ""
      echo "── Limits ──"
      echo "  Max 50 tasks per session"
      echo "  3-day auto-expiry for recurring tasks"
      echo "  Minimum interval: 1 minute (local), 1 hour (cloud)"
      ;;

    *)
      echo "🐸 Aura Frog Setup"
      echo ""
      echo "Usage: af setup <topic>"
      echo ""
      echo "Topics:"
      echo "  cli        Install af globally (type 'af' anywhere)"
      echo "  remote     Remote Control (drive from phone/browser)"
      echo "  channels   Channels (Telegram, Discord, webhooks)"
      echo "  slack      Slack MCP notifications"
      echo "  schedule   Scheduled tasks and cron jobs"
      ;;
  esac
}

# ─── Main ─────────────────────────────────────────────────────────────
case "${1:-help}" in
  setup)
    handle_setup "$2"
    ;;

  install)
    echo "🐸 Installing Aura Frog..."
    echo ""
    echo "Run in Claude Code:"
    echo "  /plugin marketplace add $REPO"
    echo "  /plugin install aura-frog@aurafrog"
    echo ""
    echo "Then install the CLI:"
    echo "  af setup cli"
    ;;

  update)
    echo "🐸 Checking for updates..."
    latest=$(curl -s "https://api.github.com/repos/$REPO/releases/latest" 2>/dev/null | grep tag_name | cut -d'"' -f4)
    if [ -n "$latest" ]; then
      echo "Current: v$VERSION"
      echo "Latest:  $latest"
      if [ "v$VERSION" = "$latest" ]; then
        echo "✅ Up to date"
      else
        echo ""
        echo "Update in Claude Code:"
        echo "  /plugin marketplace update aurafrog"
      fi
    else
      echo "Could not check latest version (no network?)"
    fi
    ;;

  version|-v|--version)
    echo "Aura Frog v$VERSION"
    ;;

  doctor)
    echo "🐸 Aura Frog Health Check"
    echo "========================="
    if [ -z "$PLUGIN_DIR" ]; then
      echo "❌ Plugin not found"
      echo "   Install: /plugin marketplace add $REPO"
      exit 1
    fi
    echo "✅ Plugin: $PLUGIN_DIR"
    echo "✅ Version: $VERSION"
    # Check hooks
    hook_count=$(ls "$PLUGIN_DIR/hooks/"*.cjs 2>/dev/null | wc -l | tr -d ' ')
    echo "✅ Hooks: $hook_count"
    # Check project context
    if [ -d ".claude/project-contexts" ]; then
      echo "✅ Project initialized"
    else
      echo "ℹ️  No project context (run project:init)"
    fi
    # Check env + trust state
    if [ -f ".envrc" ]; then
      trust_file="${HOME}/.config/aura-frog/envrc-trust.json"
      if [ -f "$trust_file" ] && command -v jq >/dev/null 2>&1; then
        expected=$(jq -r --arg p "$PWD/.envrc" '.[$p].sha256 // empty' "$trust_file" 2>/dev/null)
        if [ -n "$expected" ]; then
          if command -v sha256sum >/dev/null 2>&1; then
            current=$(sha256sum .envrc | awk '{print $1}')
          else
            current=$(shasum -a 256 .envrc | awk '{print $1}')
          fi
          if [ "$current" = "$expected" ]; then
            echo "✅ .envrc found + trusted"
          else
            echo "⚠️  .envrc found but hash changed since approval (run: af envrc allow)"
          fi
        else
          echo "⚠️  .envrc found but NOT trusted (auto-source disabled — run: af envrc allow)"
        fi
      else
        echo "⚠️  .envrc found but NOT trusted (auto-source disabled — run: af envrc allow)"
      fi
    else
      echo "ℹ️  No .envrc (optional)"
    fi
    # Check git
    git rev-parse --is-inside-work-tree &>/dev/null && echo "✅ Git repo" || echo "⚠️  Not a git repo"
    # Check CLI install
    if command -v af &>/dev/null; then
      echo "✅ CLI installed globally"
    else
      echo "ℹ️  CLI not global (run: af setup cli)"
    fi
    ;;

  measure)
    if [ -n "$PLUGIN_DIR" ] && [ -f "$PLUGIN_DIR/scripts/measure-performance.sh" ]; then
      bash "$PLUGIN_DIR/scripts/measure-performance.sh"
    else
      echo "❌ Plugin not found or measure-performance.sh missing"
    fi
    ;;

  profile)
    if [ -n "$PLUGIN_DIR" ] && [ -f "$PLUGIN_DIR/scripts/profile-hooks.sh" ]; then
      bash "$PLUGIN_DIR/scripts/profile-hooks.sh" "${2:-3}"
    else
      echo "❌ Plugin not found or profile-hooks.sh missing"
    fi
    ;;

  envrc)
    # Trust-file management for .envrc auto-sourcing.
    # Aura Frog hooks call envrc-guarded-source.sh which only sources
    # .envrc files whose sha256 matches an entry in ~/.config/aura-frog/envrc-trust.json.
    trust_dir="${HOME}/.config/aura-frog"
    trust_file="${trust_dir}/envrc-trust.json"
    envrc_path="$PWD/.envrc"

    _compute_hash() {
      if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | awk '{print $1}'
      elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$1" | awk '{print $1}'
      else
        return 1
      fi
    }

    case "${2:-status}" in
      allow)
        if [ ! -f "$envrc_path" ]; then
          echo "❌ No .envrc found in $(pwd)"
          exit 1
        fi
        hash=$(_compute_hash "$envrc_path") || { echo "❌ Need sha256sum or shasum"; exit 1; }
        mkdir -p "$trust_dir"
        [ -f "$trust_file" ] || echo '{}' > "$trust_file"
        now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        if command -v jq >/dev/null 2>&1; then
          tmp=$(mktemp)
          jq --arg p "$envrc_path" --arg s "$hash" --arg t "$now" \
            '.[$p] = { sha256: $s, approved_at: $t }' "$trust_file" > "$tmp" && mv "$tmp" "$trust_file"
        elif command -v python3 >/dev/null 2>&1; then
          python3 -c "
import json, sys, os
p, s, t, tf = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
data = json.load(open(tf)) if os.path.exists(tf) else {}
data[p] = {'sha256': s, 'approved_at': t}
json.dump(data, open(tf, 'w'), indent=2)
" "$envrc_path" "$hash" "$now" "$trust_file"
        else
          echo "❌ Need jq or python3 to update trust file"
          exit 1
        fi
        echo "✅ Approved: $envrc_path"
        echo "   sha256:  $hash"
        echo "   stored:  $trust_file"
        ;;
      revoke)
        if [ ! -f "$trust_file" ]; then
          echo "ℹ️  No trust file at $trust_file"
          exit 0
        fi
        if command -v jq >/dev/null 2>&1; then
          tmp=$(mktemp)
          jq --arg p "$envrc_path" 'del(.[$p])' "$trust_file" > "$tmp" && mv "$tmp" "$trust_file"
        elif command -v python3 >/dev/null 2>&1; then
          python3 -c "
import json, sys, os
p, tf = sys.argv[1], sys.argv[2]
data = json.load(open(tf)) if os.path.exists(tf) else {}
data.pop(p, None)
json.dump(data, open(tf, 'w'), indent=2)
" "$envrc_path" "$trust_file"
        else
          echo "❌ Need jq or python3"
          exit 1
        fi
        echo "✅ Revoked: $envrc_path"
        ;;
      status)
        echo "🐸 .envrc trust status"
        echo "===================="
        echo "Current dir: $(pwd)"
        if [ ! -f "$envrc_path" ]; then
          echo "  .envrc:    ❌ not present"
        else
          current_hash=$(_compute_hash "$envrc_path" 2>/dev/null)
          echo "  .envrc:    ✅ present"
          echo "  sha256:    $current_hash"
        fi
        if [ ! -f "$trust_file" ]; then
          echo "  Trust file: ❌ not created (run: af envrc allow)"
          exit 0
        fi
        echo "  Trust file: ✅ $trust_file"
        if [ -f "$envrc_path" ]; then
          if command -v jq >/dev/null 2>&1; then
            expected=$(jq -r --arg p "$envrc_path" '.[$p].sha256 // empty' "$trust_file" 2>/dev/null)
          else
            expected=""
          fi
          if [ -z "$expected" ]; then
            echo "  This .envrc: ❌ NOT trusted → auto-source disabled (run: af envrc allow)"
          elif [ "$expected" = "$current_hash" ]; then
            echo "  This .envrc: ✅ trusted (hash matches) → auto-source enabled"
          else
            echo "  This .envrc: ⚠️  trusted hash MISMATCH (file changed since approval)"
            echo "                  Re-approve with: af envrc allow"
          fi
        fi
        ;;
      list)
        if [ ! -f "$trust_file" ]; then
          echo "ℹ️  No trust file"
          exit 0
        fi
        if command -v jq >/dev/null 2>&1; then
          jq -r 'to_entries[] | "  \(.value.approved_at)  \(.key)"' "$trust_file"
        else
          cat "$trust_file"
        fi
        ;;
      *)
        echo "Usage: af envrc <allow|revoke|status|list>"
        echo ""
        echo "  allow    Compute sha256 of \$PWD/.envrc and store in trust file"
        echo "  revoke   Remove the trust entry for \$PWD/.envrc"
        echo "  status   Show whether \$PWD/.envrc is trusted (default)"
        echo "  list     List all trusted .envrc paths"
        echo ""
        echo "Background: hooks source .envrc only when its hash matches a"
        echo "stored entry. Closes a HIGH-severity finding where cloning a"
        echo "hostile repo would auto-execute arbitrary code."
        ;;
    esac
    ;;

  help|-h|--help|*)
    echo "🐸 Aura Frog CLI v$VERSION"
    echo ""
    echo "Usage: af <command>"
    echo ""
    echo "Commands:"
    echo "  setup      Setup guides (cli, remote, channels, slack, schedule)"
    echo "  install    Show install instructions"
    echo "  update     Check for updates"
    echo "  version    Show current version"
    echo "  doctor     Health check"
    echo "  envrc      Manage .envrc trust (allow/revoke/status/list)"
    echo "  measure    Run performance measurement"
    echo "  profile    Profile hook execution times"
    echo "  help       Show this help"
    echo ""
    echo "Quick start:"
    echo "  af setup cli       Install globally (type 'af' anywhere)"
    echo "  af setup remote    Setup remote control"
    echo "  af setup channels  Setup Telegram/Discord channels"
    ;;
esac
