  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "aura-frog",
    "ai-agents",
    "workflow",
    "tdd",
    "multi-agent",
    "react-native",
    "vue",
    "laravel",
    "nextjs",
    "flutter"
