    "redis":    { "max_calls_per_minute": 20, "max_calls_per_session": 200 },
    "playwright": { "max_calls_per_minute": 30, "max_calls_per_session": 200 },
    "vitest":   { "max_calls_per_minute": 60, "max_calls_per_session": 500 },
    "figma":    { "max_calls_per_minute": 20, "max_calls_per_session": 100 },
    "firebase": { "max_calls_per_minute": 30, "max_calls_per_session": 200 },
    "slack":    { "max_calls_per_minute": 20, "max_calls_per_session": 100 },
    "default":  { "max_calls_per_minute": 30, "max_calls_per_session": 200 }
  }
